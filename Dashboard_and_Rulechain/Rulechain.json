          "scriptLang": "JS",
          "jsScript": "// Trích xuất dữ liệu từ metadata\r\nvar tempData = metadata.temperature ? JSON.parse(metadata.temperature) : [];\r\nvar humData = metadata.humidity ? JSON.parse(metadata.humidity) : [];\r\n\r\n// Tổng số lượng dữ liệu thu thập được trong 30 giây qua (chỉ còn nhiệt độ và độ ẩm)\r\nvar totalDataCount = tempData.length + humData.length;\r\n\r\n// Nếu có dữ liệu -> Trả về True để đi tiếp tới node gửi mail\r\nreturn totalDataCount > 0;",
