        "configurationVersion": 0,
        "configuration": {
          "scriptLang": "JS",
          "jsScript": "// Biến metadata.ss_last_email_time do node Get Attributes phía trước truyền vào\r\n// Nếu chưa từng gửi (lần đầu tiên), nó sẽ trả về 0.\r\nvar lastTime = metadata.ss_last_email_time ? parseInt(metadata.ss_last_email_time) : 0;\r\nvar currentTime = new Date().getTime();\r\n\r\n// Kiểm tra xem thời điểm hiện tại đã cách lần cuối gửi >= 60,000 ms chưa\r\nreturn (currentTime - lastTime) >= 30000;",
