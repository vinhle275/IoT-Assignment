      {
        "type": "org.thingsboard.rule.engine.transform.TbTransformMsgNode",
        "name": "Format HTML Email",
        "debugSettings": {
          "failuresEnabled": true,
          "allEnabled": false,
          "allEnabledUntil": 0
        },
        "singletonMode": false,
        "queueName": null,
        "configurationVersion": 0,
        "configuration": {
          "scriptLang": "JS",
          "jsScript": "// 1. Lấy và parse dữ liệu từ metadata một cách an toàn\r\nvar tempData = metadata.temperature ? JSON.parse(metadata.temperature) : [];\r\nvar humData = metadata.humidity ? JSON.parse(metadata.humidity) : [];\r\nvar lightData = metadata.light ? JSON.parse(metadata.light) : [];\r\n\r\n// 2. Hàm tính giá trị trung bình\r\nfunction getAverage(arr) {\r\n    if (!arr || arr.length === 0) return \"\";\r\n    var sum = 0;\r\n    for (var i = 0; i < arr.length; i++) {\r\n        sum += parseFloat(arr[i].value);\r\n    }\r\n    return (sum / arr.length).toFixed(2); // Làm tròn 2 chữ số thập phân\r\n}\r\n\r\n// 3. Hàm tính giá trị trung vị\r\nfunction getMedian(arr) {\r\n    if (!arr || arr.length === 0) return \"\";\r\n    var values = [];\r\n    for (var i = 0; i < arr.length; i++) {\r\n        values.push(parseFloat(arr[i].value));\r\n    }\r\n    // Sắp xếp mảng tăng dần\r\n    values.sort(function(a, b) { return a - b; });\r\n    var half = Math.floor(values.length / 2);\r\n    \r\n    if (values.length % 2 === 0) {\r\n        return ((values[half - 1] + values[half]) / 2.0).toFixed(2);\r\n    }\r\n    return values[half].toFixed(2);\r\n}\r\n\r\n// 4. Hàm format thời gian từ chuỗi timestamp (ts) của ThingsBoard\r\nfunction formatTime(ts) {\r\n    var date = new Date(ts);\r\n    var h = date.getHours();\r\n    var m = date.getMinutes();\r\n    var s = date.getSeconds();\r\n    // Thêm số 0 đằng trước nếu nhỏ hơn 10 (vd: 09:05:02)\r\n    return (h < 10 ? '0'+h : h) + ':' + (m < 10 ? '0'+m : m) + ':' + (s < 10 ? '0'+s : s);\r\n}\r\n\r\n// 5. Bắt đầu tạo khung bảng HTML\r\nvar emailBody = \"<h3>Báo cáo dữ liệu từ thiết bị \" + metadata.deviceName + \"</h3>\";\r\nemailBody += \"<table border='1' style='border-collapse: collapse; width: 100%; text-align: center;'>\";\r\nemailBody += \"<tr style='background-color: #f2f2f2;'><th>STT</th><th>Thời gian</th><th>Nhiệt độ (C)</th><th>Độ ẩm (%)</th><th>Ánh sáng (lux)</th></tr>\";\r\n\r\n// Tìm độ dài lớn nhất của các mảng dữ liệu để lặp (thường chúng sẽ bằng nhau do gửi cùng lúc)\r\nvar maxLength = Math.max(tempData.length, humData.length, lightData.length);\r\n\r\n// 6. Điền từng hàng dữ liệu vào bảng\r\nfor (var i = 0; i < maxLength; i++) {\r\n    var stt = i + 1;\r\n    var timeStr = \"\";\r\n    var tempVal = \"\";\r\n    var humVal = \"\";\r\n    var lightVal = \"\";\r\n\r\n    // Lấy giá trị từng thông số nếu có\r\n    if (i < tempData.length) {\r\n        timeStr = formatTime(tempData[i].ts);\r\n        tempVal = tempData[i].value;\r\n    }\r\n    if (i < humData.length) {\r\n        if (!timeStr) timeStr = formatTime(humData[i].ts);\r\n        humVal = humData[i].value;\r\n    }\r\n    if (i < lightData.length) {\r\n        if (!timeStr) timeStr = formatTime(lightData[i].ts);\r\n        lightVal = lightData[i].value;\r\n    }\r\n\r\n    emailBody += \"<tr>\";\r\n    emailBody += \"<td>\" + stt + \"</td>\";\r\n    emailBody += \"<td>\" + timeStr + \"</td>\";\r\n    emailBody += \"<td>\" + tempVal + \"</td>\";\r\n    emailBody += \"<td>\" + humVal + \"</td>\";\r\n    emailBody += \"<td>\" + lightVal + \"</td>\";\r\n    emailBody += \"</tr>\";\r\n}\r\n\r\n// 7. Tính và điền hàng Trung bình\r\nemailBody += \"<tr style='font-weight: bold;'>\";\r\nemailBody += \"<td colspan='2'>Trung bình</td>\";\r\nemailBody += \"<td>\" + getAverage(tempData) + \"</td>\";\r\nemailBody += \"<td>\" + getAverage(humData) + \"</td>\";\r\nemailBody += \"<td>\" + getAverage(lightData) + \"</td>\";\r\nemailBody += \"</tr>\";\r\n\r\n// 8. Tính và điền hàng Trung vị\r\nemailBody += \"<tr style='font-weight: bold;'>\";\r\nemailBody += \"<td colspan='2'>Trung vị</td>\";\r\nemailBody += \"<td>\" + getMedian(tempData) + \"</td>\";\r\nemailBody += \"<td>\" + getMedian(humData) + \"</td>\";\r\nemailBody += \"<td>\" + getMedian(lightData) + \"</td>\";\r\nemailBody += \"</tr>\";\r\n\r\nemailBody += \"</table>\";\r\n\r\nreturn {\r\n    msg: { emailBody: emailBody },\r\n    metadata: metadata,\r\n    msgType: \"SEND_EMAIL_REQUEST\"\r\n};",
          "tbelScript": "var emailBody = \"<h3>Dữ liệu 1 phút qua từ thiết bị \" + metadata.deviceName + \"</h3><table border='1' style='border-collapse: collapse; width: 100%;'><tr><th>Thông số</th><th>Các giá trị ghi nhận</th></tr>\";\r\n\r\nfor (var key in msg) {\r\n    emailBody += \"<tr><td style='padding: 8px;'><b>\" + key + \"</b></td><td style='padding: 8px;'>\";\r\n    var values = msg[key];\r\n    var valStrings = [];\r\n\r\n    for (var i = 0; i < values.length; i++) {\r\n        valStrings.push(values[i].value);\r\n    }\r\n\r\n    emailBody += valStrings.join(\", \") + \"</td></tr>\";\r\n}\r\nemailBody += \"</table>\";\r\n\r\nreturn {\r\n    msg: { emailBody: emailBody },\r\n    metadata: metadata,\r\n    msgType: \"SEND_EMAIL_REQUEST\"\r\n};"
        },
        "additionalInfo": {
